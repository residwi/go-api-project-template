# Application
APP_NAME=ecommerce-api
APP_ENV=development
APP_PORT=8080
APP_READ_TIMEOUT=15s
APP_WRITE_TIMEOUT=15s
APP_IDLE_TIMEOUT=60s
APP_SHUTDOWN_TIMEOUT=30s
MAX_CART_ITEMS=50
ORDER_RATE_LIMIT=5

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ecommerce
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_STATEMENT_TIMEOUT=30s
DB_IDLE_IN_TX_SESSION_TIMEOUT=60s
READER_DATABASE_URL=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_ISSUER=ecommerce-api

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID,Idempotency-Key
CORS_MAX_AGE=86400

# Worker
WORKER_INTERVAL=10s
WORKER_BATCH_SIZE=10
WORKER_LEASE_DURATION=2m
WORKER_CONCURRENCY=5

# Payment
PAYMENT_GATEWAY=mock
PAYMENT_GATEWAY_URL=http://localhost:8080/mock/payment
PAYMENT_GATEWAY_TIMEOUT=10s
PAYMENT_GATEWAY_API_KEY=
PAYMENT_WEBHOOK_SECRET=webhook-secret
